pipeline {
    // Execute this pipeline on any available Jenkins agent/node
    agent any

    // Define environment variables accessible across all stages and shell scripts
    environment {
        AWS_REGION   = 'us-east-1'                                          // Target AWS Region for infrastructure deployment
        EKS_CLUSTER  = 'devops-cluster'                                     // Name of the target Amazon EKS Cluster
        ECR_REGISTRY = '217428065218.dkr.ecr.us-east-1.amazonaws.com'       // Secure AWS ECR Private Registry Uniform Resource Identifier
        ECR_REPO     = 'python-app'                                         // Targeted application repository name inside ECR
        IMAGE_TAG    = "${GIT_COMMIT}"                                      // Unique alphanumeric Git SHA used for strict image immutability tracking
    }

    stages {
        // STAGE 1: Pull the latest source code revisions
        stage('Checkout') {
            steps {
               // Dynamically tracks the exact repository and commit that fired the webhook
                checkout scm
            }
        }

        // STAGE 2: Execute code validation inside an isolated container sandbox
       stage('Unit Test') {
            steps {
                sh '''
                    echo "Checking filesystem..."
                    if [ -f "requirements.txt" ]; then
                        echo "Found requirements.txt at the current root."
                        TARGET_DIR="$(pwd)"
                    elif [ -f "Project-1/requirements.txt" ]; then
                        echo "Found requirements.txt inside Project-1."
                        TARGET_DIR="$(pwd)/Project-1"
                    else
                        echo "Searching globally for requirements.txt..."
                        REQ_PATH=$(find . -name "requirements.txt" -print -quit)
                        TARGET_DIR=$(dirname "$(realpath "$REQ_PATH")")
                    fi
                    
                    echo "Target workspace directory is: $TARGET_DIR"
                    
                    docker run --rm -v "$TARGET_DIR:/app" -w /app python:3.9 bash -c "
                        pip install -r requirements.txt &&
                        pytest --maxfail=1 --disable-warnings -q
                    "
                '''
            }
        }
        // STAGE 3: Assemble the local production Docker layer artifact
        stage('Build Docker Image') {
            steps {
                sh """
                    echo "Building local Docker image artifact..."
                    docker build -t $ECR_REPO:$IMAGE_TAG ./app
                    
                    echo "Tagging image with complete ECR registry URI mapping..."
                    docker tag $ECR_REPO:$IMAGE_TAG $ECR_REGISTRY/$ECR_REPO:$IMAGE_TAG
                """
            }
        }

        // STAGE 4: Authenticate Jenkins with the AWS Cloud Registry
        stage('Login to ECR') {
            steps {
                sh """
                    echo "Retrieving AWS ECR token handshake..."
                    aws ecr get-login-password --region $AWS_REGION | \
                    docker login --username AWS --password-stdin $ECR_REGISTRY
                """
            }
        }

        // STAGE 5: Dispatch the verified image to the secure private catalog
        stage('Push Image to ECR') {
            steps {
                sh """
                    echo "Shipping compiled image version to remote ECR registry..."
                    docker push $ECR_REGISTRY/$ECR_REPO:$IMAGE_TAG
                """
            }
        }
    
        // STAGE 6: Initiate the Kubernetes deployment loop configuration update
        stage('Deploy to EKS') {
            steps {
                sh """
                    echo "Updating local server kubeconfig file authorization profiles..."
                    aws eks update-kubeconfig --region $AWS_REGION --name $EKS_CLUSTER

                    echo "Verifying EKS Cluster nodes communication channel connectivity..."
                    kubectl get nodes

                    echo "Injecting newly pushed container image tag version into cluster deployment..."
                    kubectl set image deployment/python-app python-app=$ECR_REGISTRY/$ECR_REPO:$IMAGE_TAG
                """
            }
        }

        // STAGE 7: Validate deployment success parameters
        stage('Verify Deployment') {
            steps {
                sh '''
                    echo "Monitoring EKS cluster rolling update status..."
                    # Blocks pipeline progression until the old pods terminate and new pods pass health checks
                    kubectl rollout status deployment/python-app
                '''
            }
        }
    }

    // Post-execution definitions handling notifications and general housecleaning routines
    post {
        success {
            // Fires if every step completes without an exit error code
            echo "Pipeline run completed: Deployment SUCCESS"
        }
        failure {
            // Fires if any single step fails, tracking pipeline breakdowns immediately
            echo "Pipeline run aborted: Deployment FAILED"
        }
        always {
            echo "Executing global cleanup directives..."
            
            // Wipes out local temporary build project workspaces to prevent workspace storage footprint bloat
   /*         cleanWs()
            
            // Deletes detached and intermediate Docker images from the Jenkins EC2 host to save storage volume capacity
            sh '''
                echo "Pruning unused container storage artifacts..."
                docker image prune -f || true
      */      '''
        }
    }
}