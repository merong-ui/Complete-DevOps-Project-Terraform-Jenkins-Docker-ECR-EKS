pipeline {

    // Execute this pipeline on any available Jenkins agent/node
    agent any

    // Global environment variables
    environment {

        AWS_REGION   = '<AWS_REGION>'
        EKS_CLUSTER  = '<EKS_CLUSTER_NAME>'

        ECR_REGISTRY = '<AWS_ACCOUNT_ID>.dkr.ecr.<AWS_REGION>.amazonaws.com'
        ECR_REPO     = '<ECR_REPOSITORY_NAME>'

        // Git commit SHA used as immutable image tag
        IMAGE_TAG    = "${GIT_COMMIT}"
    }

    stages {

        // STAGE 1: Pull latest source code
        stage('Checkout') {

            steps {

                // Uses Jenkins SCM configuration
                checkout scm
            }
        }

        // STAGE 2: Run unit tests inside a clean Python container
        stage('Unit Test') {

            agent {

                docker {
                    image 'python:3.11-slim'
                }
            }

            steps {

                sh '''
                    echo "Installing dependencies"

                    pip install -r app/requirements.txt

                    echo "Running unit tests"

                    python -m unittest discover
                '''
            }
        }

        // STAGE 3: Build Docker image
        stage('Build Docker Image') {

            steps {

                sh """
                    echo "Building Docker Image"

                    docker build \
                    -t ${ECR_REPO}:${IMAGE_TAG} \
                    ./app

                    echo "Tagging Image for ECR"

                    docker tag \
                    ${ECR_REPO}:${IMAGE_TAG} \
                    ${ECR_REGISTRY}/${ECR_REPO}:${IMAGE_TAG}
                """
            }
        }

        // STAGE 4: Authenticate to Amazon ECR
        stage('Login to ECR') {

            steps {

                sh """
                    echo "Logging into Amazon ECR"

                    aws ecr get-login-password \
                    --region ${AWS_REGION} | \
                    docker login \
                    --username AWS \
                    --password-stdin ${ECR_REGISTRY}
                """
            }
        }

        // STAGE 5: Push image to Amazon ECR
        stage('Push Image to ECR') {

            steps {

                sh """
                    echo "Pushing Docker image"

                    docker push \
                    ${ECR_REGISTRY}/${ECR_REPO}:${IMAGE_TAG}
                """
            }
        }

        // STAGE 6: Deploy new image to Amazon EKS
        stage('Deploy to EKS') {

            steps {

                sh """
                    echo "Updating kubeconfig"

                    aws eks update-kubeconfig \
                        --region ${AWS_REGION} \
                        --name ${EKS_CLUSTER}

                    echo "Verifying Cluster Connectivity"

                    kubectl get nodes

                    echo "Updating Kubernetes Deployment"

                    kubectl set image deployment/python-app \
                    python-app=${ECR_REGISTRY}/${ECR_REPO}:${IMAGE_TAG}
                """
            }
        }

        // STAGE 7: Verify deployment rollout
        stage('Verify Deployment') {

            steps {

                sh '''
                    echo "Waiting for deployment rollout"

                    kubectl rollout status deployment/python-app
                '''
            }
        }
    }

    // Post-build actions
    post {

        success {

            echo "Deployment SUCCESS"
        }

        failure {

            echo "Deployment FAILED"
        }

        always {

            echo "Cleaning workspace"

            cleanWs()

            sh '''
                echo "Removing unused Docker images"

                docker image prune -f || true
            '''
        }
    }
}
